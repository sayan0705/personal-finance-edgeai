# LLM backend for chat, sentiment analysis, tool selection, and grounded generation
LLM_BASE_URL=http://95.253.220.115:63084/v1
LLM_API_KEY=BANYAN_TREE_LLM_API_KEY
LLM_MODEL=Qwen/Qwen3-8B
BANYANTREE_LLM_PROVIDER=api
BANYANTREE_API_MODEL=Qwen/Qwen3-8B
BANYANTREE_API_BASE_URL=http://95.253.220.115:63084/v1
BANYANTREE_API_KEY=BANYAN_TREE_LLM_API_KEY
BANYANTREE_SKIP_MCP_BOOTSTRAP=1
BANYANTREE_MCP_BASE=http://mcp-tools:8010

# API authentication
API_KEY=finedge-local-key-change-me

# BanyanTree file-based KG + PageIndex paths
BANYANTREE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
BANYANTREE_DATA_DIR=/app/data
BANYANTREE_FINANCIAL_KG_ROOT=/app/data/financial_kg
BANYANTREE_RAW_DOCS_DIR=/app/data/financial_kg/raw_docs
BANYANTREE_SEED_DOCS_PATH=/app/data/financial_kg/raw_docs/seed/personal_finance_seed.json
BANYANTREE_PAGEINDEX_FLATTENED_DOCS_PATH=/app/data/financial_kg/raw_docs/pageindex/pageindex_flattened_docs.json
BANYANTREE_PAGEINDEX_INPUT_DIR=/app/data/financial_kg/pageindex/inputs
BANYANTREE_PAGEINDEX_OUTPUT_DIR=/app/data/financial_kg/pageindex/outputs
BANYANTREE_PAGEINDEX_STRUCTURES_DIR=/app/data/financial_kg/pageindex/structures
FINSAGE_KG_PATH=/app/data/financial_kg/lightrag
BANYANTREE_SHOW_FLOW_TRACE=true

# No vector DB in this design
RAG_ENABLED=false

# Logging
LOG_LEVEL=INFO
