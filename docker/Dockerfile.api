FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# API + container shell
RUN pip install --no-cache-dir --timeout 300 \
    fastapi>=0.109.0 \
    "uvicorn[standard]>=0.27.0" \
    httpx>=0.26.0 \
    "pydantic>=2.0.0" \
    pyyaml>=6.0.1 \
    loguru>=0.7.0 \
    python-dotenv>=1.0.0 \
    python-multipart>=0.0.9 \
    yfinance>=0.2.50
# Pin numpy<2.0 before torch so pip never resolves numpy 2.x.
# faiss-cpu==1.8.0 C extension was compiled against numpy 1.x ABI;
# numpy 2.x removed numpy.core.multiarray which faiss requires at runtime.
RUN pip install --no-cache-dir --timeout 300 "numpy>=1.24,<2.0"

# CPU-only torch — the API uses an external LLM endpoint, no GPU needed.
# This cuts the download from ~3 GB (CUDA) to ~200 MB.
RUN pip install --no-cache-dir --timeout 300 \
    torch --index-url https://download.pytorch.org/whl/cpu

# Original BanyanTree RAG runtime dependencies.
# Chat/generation uses the OpenAI-compatible Qwen API, but the original RAG
# still imports/uses embeddings, FAISS, BM25, KG, clustering, and guardrails.
RUN pip install --no-cache-dir --timeout 300 \
    transformers==4.44.0 \
    sentence-transformers==3.0.1 \
    faiss-cpu==1.8.0 \
    rank-bm25==0.2.2 \
    networkx==3.3 \
    scikit-learn==1.4.2 \
    "spacy>=3.7,<3.9" \
    pandas \
    beautifulsoup4 \
    lxml \
    nest_asyncio \
    presidio-analyzer \
    presidio-anonymizer \
    pypdf>=4.0.0 \
    python-multipart>=0.0.9

# en_core_web_sm — used by both BanyanTree NER (line 1353) and Presidio (configured via
# NlpEngineProvider in FinancialPIIRedactor.__init__). Baked into image — no runtime download.
RUN python -m spacy download en_core_web_sm

COPY app/ ./app/
COPY agents/ ./agents/
COPY rag/ ./rag/
COPY configs/ ./configs/
COPY src/ ./src/
COPY scripts/ ./scripts/
COPY data/ ./data/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/model-cache
ENV TRANSFORMERS_CACHE=/model-cache/transformers
ENV SENTENCE_TRANSFORMERS_HOME=/model-cache/sentence-transformers
ENV BANYANTREE_SKIP_MCP_BOOTSTRAP=1
ENV BANYANTREE_MCP_BASE=http://mcp-tools:8010
ENV BANYANTREE_LLM_PROVIDER=api
ENV BANYANTREE_DATA_DIR=/app/data
ENV BANYANTREE_FINANCIAL_KG_ROOT=/app/data/financial_kg
ENV BANYANTREE_RAW_DOCS_DIR=/app/data/financial_kg/raw_docs
ENV BANYANTREE_SEED_DOCS_PATH=/app/data/financial_kg/raw_docs/seed/personal_finance_seed.json
ENV BANYANTREE_PAGEINDEX_FLATTENED_DOCS_PATH=/app/data/financial_kg/raw_docs/pageindex/pageindex_flattened_docs.json
ENV BANYANTREE_PAGEINDEX_INPUT_DIR=/app/data/financial_kg/pageindex/inputs
ENV RAG_ENABLED=false

EXPOSE 8000

CMD ["uvicorn", "app.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
